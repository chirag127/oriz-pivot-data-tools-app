---
import '~/styles/global.css'
import { pricingUrl } from '@chirag127/astro-shell/pricing-url'
import FamilySidebar from '@chirag127/astro-shell/components/FamilySidebar.astro'

interface Props {
  title?: string
  description?: string
}

const { title = 'Oriz Pivot — Spreadsheets without uploading them.', description = 'CSV / JSON / Excel / TSV / YAML. Sort, filter, group, pivot, aggregate, dedupe, type-coerce. Chart with ECharts.' } = Astro.props
const canonical = new URL(Astro.url.pathname, 'https://data.oriz.in').toString()
const pricingHref = pricingUrl('oriz-pivot-data-tools-app')
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header class="site">
      <a class="wordmark" href="/">Pivot</a>
      <nav>
        <a href="/">tools</a>
        <a href="/about/">about</a>
        <a href={pricingHref}>pricing</a>
        <a href="https://account.oriz.in/sign-in">sign in</a>
      </nav>
    </header>
    <div class="oriz-shell">
      <FamilySidebar slug="oriz-pivot-data-tools-app" title="Pivot Tools">
        <a slot="tools" href="/tools/aggregate/">Aggregate</a>
        <a slot="tools" href="/tools/chart/">Chart</a>
        <a slot="tools" href="/tools/coerce/">Type Coerce</a>
        <a slot="tools" href="/tools/column-extractor/">Column Extractor</a>
        <a slot="tools" href="/tools/csv-json/">CSV → JSON</a>
        <a slot="tools" href="/tools/csv-viewer/">CSV Viewer</a>
        <a slot="tools" href="/tools/dedupe/">Deduplicate</a>
        <a slot="tools" href="/tools/excel/">CSV ↔ Excel</a>
        <a slot="tools" href="/tools/group/">Group By</a>
        <a slot="tools" href="/tools/json-csv/">JSON → CSV</a>
        <a slot="tools" href="/tools/json-query/">JSON Query</a>
        <a slot="tools" href="/tools/pivot/">Pivot Table</a>
        <a slot="tools" href="/tools/rename/">Rename Columns</a>
        <a slot="tools" href="/tools/sort-filter/">Sort &amp; Filter</a>
        <a slot="tools" href="/tools/stats/">Stats</a>
        <a slot="tools" href="/tools/tsv-yaml/">TSV ↔ YAML</a>
      </FamilySidebar>
      <main id="main" class="oriz-main"><slot /></main>
    </div>
    <footer class="site">
      <span>Oriz Pivot · part of the <a href="https://oriz.in">oriz</a> family · runs in your browser</span>
      <span>
        <a href="/about/">about</a> · <a href="/contact/">contact</a> · <a href="/legal/privacy/">privacy</a> · <a href="/legal/terms/">terms</a> · <a href="/legal/disclaimer/">disclaimer</a>
      </span>
    </footer>
  </body>
</html>
