---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="JSON Query (JSONPath) — Oriz Pivot" description="Paste JSON and a JSONPath expression to see matching results. Powered by jsonpath-plus. Runs in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">JSON Query (JSONPath)</h1>
    <p class="status mono ready">ready · v0.1</p>

    <div class="controls">
      <label class="label-text" for="json-input">Paste JSON:</label>
      <textarea id="json-input" class="io" placeholder='{"store":{"books":[{"title":"Moby Dick","price":8.99},{"title":"1984","price":12.50}]}}' rows="7" spellcheck="false"></textarea>

      <label class="label-text" for="path-input">JSONPath expression:</label>
      <div class="path-row">
        <input id="path-input" class="path-box" type="text" placeholder="$.store.books[*].title" spellcheck="false" />
        <button id="query-btn" class="btn primary">Run query</button>
        <button id="clear-btn" class="btn">Clear</button>
      </div>

      <p class="hint mono">Examples: <code>$.store.books[*].title</code> · <code>$..price</code> · <code>$.store.books[?(@.price &lt; 10)]</code></p>
    </div>

    <div id="output-wrap" style="display:none">
      <label class="label-text" for="result-output">Results:</label>
      <textarea id="result-output" class="io" rows="10" spellcheck="false" readonly></textarea>
    </div>
    <p id="status-msg" class="hint mono"></p>
  </article>
</BaseLayout>

<script>
  import { JSONPath } from 'jsonpath-plus'

  const jsonInput = document.getElementById('json-input') as HTMLTextAreaElement
  const pathInput = document.getElementById('path-input') as HTMLInputElement
  const queryBtn = document.getElementById('query-btn') as HTMLButtonElement
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement
  const resultOutput = document.getElementById('result-output') as HTMLTextAreaElement
  const outputWrap = document.getElementById('output-wrap') as HTMLDivElement
  const statusMsg = document.getElementById('status-msg') as HTMLParagraphElement

  queryBtn.addEventListener('click', () => {
    const raw = jsonInput.value.trim()
    if (!raw) { statusMsg.textContent = 'Paste JSON first.'; return }
    const path = pathInput.value.trim()
    if (!path) { statusMsg.textContent = 'Enter a JSONPath expression.'; return }

    let data: unknown
    try {
      data = JSON.parse(raw)
    } catch (e: unknown) {
      const msg = e instanceof Error ? e.message : String(e)
      statusMsg.textContent = 'JSON parse error: ' + msg; return
    }

    let results: unknown[]
    try {
      results = JSONPath({ path, json: data as object })
    } catch (e: unknown) {
      const msg = e instanceof Error ? e.message : String(e)
      statusMsg.textContent = 'JSONPath error: ' + msg; return
    }

    resultOutput.value = JSON.stringify(results, null, 2)
    outputWrap.style.display = ''
    statusMsg.textContent = `${results.length} match${results.length !== 1 ? 'es' : ''}.`
  })

  pathInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') queryBtn.click() })

  clearBtn.addEventListener('click', () => {
    jsonInput.value = ''; pathInput.value = ''; resultOutput.value = ''
    outputWrap.style.display = 'none'; statusMsg.textContent = ''
  })
</script>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .label-text { font-size: 0.875rem; color: var(--muted); margin-bottom: 0.25rem; display: block; }
  .controls { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.5rem; }
  .io { width: 100%; padding: 0.875rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--ink); font-family: var(--font-mono); font-size: 0.8125rem; resize: vertical; }
  .io:focus { outline: 2px solid var(--accent); outline-offset: 1px; }
  .path-row { display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: stretch; }
  .path-box {
    flex: 1;
    min-width: 0;
    padding: 0.5rem 0.875rem;
    border: 1px solid var(--rule);
    background: var(--paper-2);
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }
  .path-box:focus { outline: 2px solid var(--accent); outline-offset: 1px; }
  #output-wrap { display: flex; flex-direction: column; gap: 0.5rem; }
  code { background: var(--paper-2); padding: 0.15em 0.4em; border-radius: 3px; font-family: var(--font-mono); font-size: 0.85em; }
  .btn-row { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .btn { padding: 0.5rem 1rem; border: 1px solid var(--rule); background: var(--paper-2); color: var(--ink); font-family: var(--font-display); font-size: 0.875rem; cursor: pointer; white-space: nowrap; }
  .btn:hover { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn.primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn.primary:hover { opacity: 0.85; }
  .hint { font-size: 11px; color: var(--muted); margin-top: 0.5rem; }
</style>
