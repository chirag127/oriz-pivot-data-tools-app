---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="CSV Viewer / Editor — Oriz Pivot" description="Paste CSV and get an interactive sortable/filterable table. Edit cells and download the updated CSV. Runs in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">CSV Viewer / Editor</h1>
    <p class="status mono ready">ready · v0.1</p>

    <div class="controls">
      <textarea id="csv-input" class="io" placeholder="Paste CSV here…" rows="5" spellcheck="false"></textarea>
      <div class="btn-row">
        <button id="load-btn" class="btn primary">Load table</button>
        <button id="download-btn" class="btn" disabled>Download CSV</button>
        <button id="clear-btn" class="btn">Clear</button>
      </div>
      <input type="text" id="filter-input" class="filter-box" placeholder="Filter rows…" style="display:none" />
    </div>

    <div id="table-wrap" class="table-wrap"></div>
    <p id="row-count" class="hint mono" style="display:none"></p>
  </article>
</BaseLayout>

<script>
  import Papa from 'papaparse'

  let currentData: string[][] = []
  let currentHeaders: string[] = []
  let sortCol: number | null = null
  let sortAsc = true

  const csvInput = document.getElementById('csv-input') as HTMLTextAreaElement
  const loadBtn = document.getElementById('load-btn') as HTMLButtonElement
  const downloadBtn = document.getElementById('download-btn') as HTMLButtonElement
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement
  const filterInput = document.getElementById('filter-input') as HTMLInputElement
  const tableWrap = document.getElementById('table-wrap') as HTMLDivElement
  const rowCount = document.getElementById('row-count') as HTMLParagraphElement

  function renderTable(headers: string[], rows: string[][], filterText: string = '') {
    const q = filterText.toLowerCase()
    const filtered = q ? rows.filter(r => r.some(c => String(c).toLowerCase().includes(q))) : rows

    if (!filtered.length) {
      tableWrap.innerHTML = '<p class="hint mono">No rows match the filter.</p>'
      rowCount.textContent = '0 rows shown'
      rowCount.style.display = ''
      return
    }

    rowCount.textContent = `${filtered.length} row${filtered.length !== 1 ? 's' : ''} shown`
    rowCount.style.display = ''

    const table = document.createElement('table')
    table.className = 'data-table'

    const thead = document.createElement('thead')
    const hrow = document.createElement('tr')
    headers.forEach((h, i) => {
      const th = document.createElement('th')
      th.textContent = h
      th.dataset.col = String(i)
      th.title = 'Click to sort'
      if (sortCol === i) th.classList.add(sortAsc ? 'sort-asc' : 'sort-desc')
      th.addEventListener('click', () => {
        if (sortCol === i) { sortAsc = !sortAsc } else { sortCol = i; sortAsc = true }
        const sorted = [...currentData].sort((a, b) => {
          const av = a[i] ?? '', bv = b[i] ?? ''
          const n = Number(av) - Number(bv)
          const cmp = isNaN(n) ? av.localeCompare(bv) : n
          return sortAsc ? cmp : -cmp
        })
        currentData = sorted
        renderTable(headers, sorted, filterInput.value)
      })
      hrow.appendChild(th)
    })
    // extra th for row delete
    const delTh = document.createElement('th')
    delTh.textContent = ''
    delTh.className = 'del-col'
    hrow.appendChild(delTh)
    thead.appendChild(hrow)
    table.appendChild(thead)

    const tbody = document.createElement('tbody')
    filtered.forEach((row, ri) => {
      const tr = document.createElement('tr')
      row.forEach((cell, ci) => {
        const td = document.createElement('td')
        td.contentEditable = 'true'
        td.textContent = cell
        td.addEventListener('input', () => {
          // find real row index in currentData
          const realRow = currentData.indexOf(row)
          if (realRow >= 0) currentData[realRow][ci] = td.textContent ?? ''
        })
        td.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); td.blur() } })
        tr.appendChild(td)
      })
      // delete row btn
      const delTd = document.createElement('td')
      delTd.className = 'del-col'
      const delBtn = document.createElement('button')
      delBtn.textContent = '×'
      delBtn.className = 'del-btn'
      delBtn.title = 'Delete row'
      delBtn.addEventListener('click', () => {
        const realRow = currentData.indexOf(row)
        if (realRow >= 0) currentData.splice(realRow, 1)
        renderTable(currentHeaders, currentData, filterInput.value)
      })
      delTd.appendChild(delBtn)
      tr.appendChild(delTd)
      tbody.appendChild(tr)
    })
    table.appendChild(tbody)

    tableWrap.innerHTML = ''
    tableWrap.appendChild(table)
  }

  loadBtn.addEventListener('click', () => {
    const raw = csvInput.value.trim()
    if (!raw) return
    const result = Papa.parse<string[]>(raw, { skipEmptyLines: true })
    if (result.errors.length && !result.data.length) {
      tableWrap.innerHTML = '<p class="hint mono" style="color:red">Parse error: ' + result.errors[0].message + '</p>'
      return
    }
    const [headers, ...rows] = result.data as string[][]
    currentHeaders = headers
    currentData = rows
    sortCol = null
    sortAsc = true
    filterInput.style.display = ''
    downloadBtn.disabled = false
    renderTable(currentHeaders, currentData)
  })

  filterInput.addEventListener('input', () => {
    renderTable(currentHeaders, currentData, filterInput.value)
  })

  downloadBtn.addEventListener('click', () => {
    const csv = Papa.unparse([currentHeaders, ...currentData])
    const blob = new Blob([csv], { type: 'text/csv' })
    const url = URL.createObjectURL(blob)
    const a = document.createElement('a')
    a.href = url; a.download = 'edited.csv'; a.click()
    URL.revokeObjectURL(url)
  })

  clearBtn.addEventListener('click', () => {
    csvInput.value = ''
    tableWrap.innerHTML = ''
    currentData = []; currentHeaders = []
    filterInput.style.display = 'none'; filterInput.value = ''
    downloadBtn.disabled = true
    rowCount.style.display = 'none'
  })
</script>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }

  .controls { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.5rem; }
  .io {
    width: 100%;
    padding: 0.875rem;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    resize: vertical;
  }
  .io:focus { outline: 2px solid var(--accent); outline-offset: 1px; }
  .filter-box {
    width: 100%;
    padding: 0.625rem 0.875rem;
    border: 1px solid var(--rule);
    background: var(--paper-2);
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 0.875rem;
  }
  .filter-box:focus { outline: 2px solid var(--accent); outline-offset: 1px; }

  .btn-row { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .btn {
    padding: 0.5rem 1rem;
    border: 1px solid var(--rule);
    background: var(--paper-2);
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 0.875rem;
    cursor: pointer;
  }
  .btn:hover { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn.primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn.primary:hover { opacity: 0.85; }
  .btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .btn:disabled:hover { background: var(--paper-2); color: var(--ink); border-color: var(--rule); }

  .table-wrap { overflow-x: auto; margin-bottom: 1rem; }
  .data-table { border-collapse: collapse; min-width: 100%; font-size: 0.875rem; }
  .data-table th, .data-table td { border: 1px solid var(--rule); padding: 0.4rem 0.75rem; text-align: left; white-space: nowrap; }
  .data-table th { background: var(--paper-2); font-weight: 600; cursor: pointer; user-select: none; }
  .data-table th:hover { background: color-mix(in oklab, var(--paper-2) 70%, var(--accent) 30%); }
  .data-table th.sort-asc::after { content: ' ↑'; font-size: 10px; }
  .data-table th.sort-desc::after { content: ' ↓'; font-size: 10px; }
  .data-table td[contenteditable]:focus { outline: 2px solid var(--accent); outline-offset: -2px; background: color-mix(in oklab, var(--paper) 90%, var(--accent) 10%); }
  .data-table tbody tr:hover { background: var(--paper-2); }
  .del-col { width: 2rem; text-align: center; padding: 0.25rem !important; }
  .del-btn { background: none; border: none; color: var(--muted); cursor: pointer; font-size: 1rem; padding: 0; line-height: 1; }
  .del-btn:hover { color: red; }

  .hint { font-size: 11px; color: var(--muted); }
</style>
