---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Column Extractor — Oriz Pivot" description="Paste CSV, pick the columns to keep, download the subset. Runs in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">Column Extractor</h1>
    <p class="status mono ready">ready · v0.1</p>

    <div class="controls">
      <label class="label-text" for="csv-input">Paste CSV (first row = headers):</label>
      <textarea id="csv-input" class="io" placeholder="name,age,city,email&#10;Alice,30,NYC,alice@example.com&#10;Bob,25,LA,bob@example.com" rows="7" spellcheck="false"></textarea>
      <div id="col-section" style="display:none">
        <p class="label-text">Select columns to keep:</p>
        <div id="col-checks" class="col-checks"></div>
        <div class="btn-row">
          <button id="extract-btn" class="btn primary">Extract columns</button>
          <button id="download-btn" class="btn" disabled>Download CSV</button>
        </div>
      </div>
      <div class="btn-row" id="parse-row">
        <button id="parse-btn" class="btn primary">Parse CSV</button>
        <button id="clear-btn" class="btn">Clear</button>
      </div>
    </div>

    <p id="status-msg" class="hint mono"></p>
    <div id="table-wrap" class="table-wrap"></div>
  </article>
</BaseLayout>

<script>
  import Papa from 'papaparse'

  const csvInput = document.getElementById('csv-input') as HTMLTextAreaElement
  const parseBtn = document.getElementById('parse-btn') as HTMLButtonElement
  const extractBtn = document.getElementById('extract-btn') as HTMLButtonElement
  const downloadBtn = document.getElementById('download-btn') as HTMLButtonElement
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement
  const colSection = document.getElementById('col-section') as HTMLDivElement
  const colChecks = document.getElementById('col-checks') as HTMLDivElement
  const parseRow = document.getElementById('parse-row') as HTMLDivElement
  const statusMsg = document.getElementById('status-msg') as HTMLParagraphElement
  const tableWrap = document.getElementById('table-wrap') as HTMLDivElement

  let headers: string[] = []
  let rows: string[][] = []
  let extractedHeaders: string[] = []
  let extractedRows: string[][] = []

  function renderPreview(h: string[], r: string[][], label: string) {
    statusMsg.textContent = label
    const table = document.createElement('table')
    table.className = 'data-table'
    const thead = document.createElement('thead')
    const hrow = document.createElement('tr')
    h.forEach(col => { const th = document.createElement('th'); th.textContent = col; hrow.appendChild(th) })
    thead.appendChild(hrow); table.appendChild(thead)
    const tbody = document.createElement('tbody')
    r.slice(0, 50).forEach(row => {
      const tr = document.createElement('tr')
      row.forEach(cell => { const td = document.createElement('td'); td.textContent = cell; tr.appendChild(td) })
      tbody.appendChild(tr)
    })
    table.appendChild(tbody)
    tableWrap.innerHTML = ''; tableWrap.appendChild(table)
    if (r.length > 50) {
      const note = document.createElement('p'); note.className = 'hint mono'
      note.textContent = `Showing first 50 of ${r.length} rows.`; tableWrap.appendChild(note)
    }
  }

  parseBtn.addEventListener('click', () => {
    const raw = csvInput.value.trim()
    if (!raw) { statusMsg.textContent = 'Paste CSV first.'; return }
    const result = Papa.parse<string[]>(raw, { skipEmptyLines: true })
    if (result.errors.length && !result.data.length) { statusMsg.textContent = 'Parse error: ' + result.errors[0].message; return }
    const [h, ...r] = result.data as string[][]
    headers = h; rows = r
    colChecks.innerHTML = ''
    headers.forEach((col, i) => {
      const label = document.createElement('label'); label.className = 'check-label'
      const cb = document.createElement('input'); cb.type = 'checkbox'; cb.value = String(i); cb.checked = true; cb.id = `col-cb-${i}`
      label.appendChild(cb); label.append(' ' + col); colChecks.appendChild(label)
    })
    colSection.style.display = ''; parseRow.style.display = 'none'
    renderPreview(headers, rows, `${rows.length} rows, ${headers.length} columns. Uncheck columns to exclude.`)
  })

  extractBtn.addEventListener('click', () => {
    const keepCols = Array.from(colChecks.querySelectorAll<HTMLInputElement>('input:checked')).map(cb => Number(cb.value))
    if (!keepCols.length) { statusMsg.textContent = 'Select at least one column.'; return }
    extractedHeaders = keepCols.map(i => headers[i])
    extractedRows = rows.map(row => keepCols.map(i => row[i] ?? ''))
    downloadBtn.disabled = false
    renderPreview(extractedHeaders, extractedRows, `Extracted ${keepCols.length} column${keepCols.length !== 1 ? 's' : ''}, ${extractedRows.length} rows.`)
  })

  downloadBtn.addEventListener('click', () => {
    const csv = Papa.unparse([extractedHeaders, ...extractedRows])
    const blob = new Blob([csv], { type: 'text/csv' })
    const url = URL.createObjectURL(blob)
    const a = document.createElement('a'); a.href = url; a.download = 'extracted.csv'; a.click()
    URL.revokeObjectURL(url)
  })

  clearBtn.addEventListener('click', () => {
    csvInput.value = ''; tableWrap.innerHTML = ''; statusMsg.textContent = ''
    headers = []; rows = []; extractedHeaders = []; extractedRows = []
    colSection.style.display = 'none'; parseRow.style.display = ''
    downloadBtn.disabled = true
  })
</script>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .label-text { font-size: 0.875rem; color: var(--muted); margin-bottom: 0.25rem; display: block; }
  .controls { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.5rem; }
  .io { width: 100%; padding: 0.875rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--ink); font-family: var(--font-mono); font-size: 0.8125rem; resize: vertical; }
  .io:focus { outline: 2px solid var(--accent); outline-offset: 1px; }
  .col-checks { display: flex; flex-wrap: wrap; gap: 0.5rem 1.25rem; margin: 0.5rem 0; }
  .check-label { display: flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; cursor: pointer; }
  .btn-row { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .btn { padding: 0.5rem 1rem; border: 1px solid var(--rule); background: var(--paper-2); color: var(--ink); font-family: var(--font-display); font-size: 0.875rem; cursor: pointer; }
  .btn:hover { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn.primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn.primary:hover { opacity: 0.85; }
  .btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .btn:disabled:hover { background: var(--paper-2); color: var(--ink); border-color: var(--rule); }
  .table-wrap { overflow-x: auto; margin-top: 1rem; }
  .data-table { border-collapse: collapse; min-width: 100%; font-size: 0.875rem; }
  .data-table th, .data-table td { border: 1px solid var(--rule); padding: 0.4rem 0.75rem; text-align: left; white-space: nowrap; }
  .data-table th { background: var(--paper-2); font-weight: 600; }
  .data-table tbody tr:hover { background: var(--paper-2); }
  .hint { font-size: 11px; color: var(--muted); margin-top: 0.5rem; }
</style>
