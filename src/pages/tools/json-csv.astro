---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="JSON → CSV — Oriz Pivot" description="Paste a JSON array and download it as a CSV file. Runs in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">JSON → CSV</h1>
    <p class="status mono ready">ready · v0.1</p>

    <div class="controls">
      <label class="label-text" for="json-input">Paste JSON array of objects:</label>
      <textarea id="json-input" class="io" placeholder='[{"name":"Alice","age":30},{"name":"Bob","age":25}]' rows="8" spellcheck="false"></textarea>
      <div class="btn-row">
        <button id="convert-btn" class="btn primary">Convert to CSV</button>
        <button id="download-btn" class="btn" disabled>Download CSV</button>
        <button id="clear-btn" class="btn">Clear</button>
      </div>
    </div>

    <div id="output-wrap">
      <label class="label-text" for="csv-output" style="display:none" id="csv-label">CSV output:</label>
      <textarea id="csv-output" class="io" rows="10" spellcheck="false" readonly style="display:none"></textarea>
    </div>
    <p id="status-msg" class="hint mono"></p>
  </article>
</BaseLayout>

<script>
  import Papa from 'papaparse'

  const jsonInput = document.getElementById('json-input') as HTMLTextAreaElement
  const convertBtn = document.getElementById('convert-btn') as HTMLButtonElement
  const downloadBtn = document.getElementById('download-btn') as HTMLButtonElement
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement
  const csvOutput = document.getElementById('csv-output') as HTMLTextAreaElement
  const csvLabel = document.getElementById('csv-label') as HTMLLabelElement
  const statusMsg = document.getElementById('status-msg') as HTMLParagraphElement

  let csvString = ''

  convertBtn.addEventListener('click', () => {
    const raw = jsonInput.value.trim()
    if (!raw) { statusMsg.textContent = 'Paste a JSON array first.'; return }
    let data: Record<string, unknown>[]
    try {
      data = JSON.parse(raw)
    } catch (e: unknown) {
      const msg = e instanceof Error ? e.message : String(e)
      statusMsg.textContent = 'JSON parse error: ' + msg
      return
    }
    if (!Array.isArray(data)) { statusMsg.textContent = 'Input must be a JSON array.'; return }
    csvString = Papa.unparse(data)
    csvOutput.value = csvString
    csvOutput.style.display = ''
    csvLabel.style.display = ''
    downloadBtn.disabled = false
    statusMsg.textContent = `${data.length} row${data.length !== 1 ? 's' : ''} converted.`
  })

  downloadBtn.addEventListener('click', () => {
    const blob = new Blob([csvString], { type: 'text/csv' })
    const url = URL.createObjectURL(blob)
    const a = document.createElement('a'); a.href = url; a.download = 'output.csv'; a.click()
    URL.revokeObjectURL(url)
  })

  clearBtn.addEventListener('click', () => {
    jsonInput.value = ''; csvOutput.value = ''; csvOutput.style.display = 'none'
    csvLabel.style.display = 'none'; statusMsg.textContent = ''; downloadBtn.disabled = true
  })
</script>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .label-text { font-size: 0.875rem; color: var(--muted); margin-bottom: 0.25rem; display: block; }
  .controls { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.5rem; }
  .io { width: 100%; padding: 0.875rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--ink); font-family: var(--font-mono); font-size: 0.8125rem; resize: vertical; }
  .io:focus { outline: 2px solid var(--accent); outline-offset: 1px; }
  #output-wrap { display: flex; flex-direction: column; gap: 0.5rem; }
  .btn-row { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .btn { padding: 0.5rem 1rem; border: 1px solid var(--rule); background: var(--paper-2); color: var(--ink); font-family: var(--font-display); font-size: 0.875rem; cursor: pointer; }
  .btn:hover { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn.primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn.primary:hover { opacity: 0.85; }
  .btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .btn:disabled:hover { background: var(--paper-2); color: var(--ink); border-color: var(--rule); }
  .hint { font-size: 11px; color: var(--muted); margin-top: 0.5rem; }
</style>
